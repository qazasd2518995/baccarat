# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/baccarat"

# JWT Secret (generate a secure random string for production)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Server
PORT=3001
NODE_ENV=production

# CORS (comma-separated origins for frontend and admin)
CORS_ORIGIN="https://baccarat-frontend.onrender.com,https://baccarat-admin.onrender.com"

# BG integration
# Must match BG API BACCARAT_INTEGRATION_SECRET
BG_INTEGRATION_SECRET="change-me-to-the-same-shared-secret-as-bg"
BG_API_BASE="https://bg-api.onrender.com"
